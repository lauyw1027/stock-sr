{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/client/**", "dist/index.cjs", "data/**"],
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "handle": "filesystem" }
  ],
  "crons": [
    {
      "path": "/api/credit-monitor/trigger",
      "schedule": "0 6 * * *"
    }
  ]
}
