{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",

      "config": {
        "distDir": "dist/client"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/client/**", "dist/index.js"]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "dist/index.cjs" },
    { "handle": "filesystem" }
  ]
}
